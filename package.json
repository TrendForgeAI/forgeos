{
  "name": "forgeos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && next build && tsc --project tsconfig.server.json",
    "start": "node server.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "playwright test",
    "test:api": "playwright test tests/api.spec.ts --project=api",
    "test:e2e": "playwright test --project=e2e",
    "test:report": "playwright show-report playwright-report",
    "test:install": "playwright install chromium --with-deps"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@prisma/client": "^6.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^2.4.3",
    "codemirror": "^6.0.2",
    "cookie": "^1.0.1",
    "next": "15.2.4",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.2.4",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
