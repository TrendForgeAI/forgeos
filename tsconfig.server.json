{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", ".next", "src"]
}
