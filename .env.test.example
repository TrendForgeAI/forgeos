# Playwright E2E Test Environment
# Copy this to .env.test and fill in the values, then: source .env.test

# Target URL of the ForgeOS instance under test
FORGEOS_URL=https://forgeos.trend-forge.dev

# Admin credentials (created during setup wizard)
TEST_ADMIN_EMAIL=trendforge.ai@gmail.com
TEST_ADMIN_PASSWORD=your-admin-password-here
TEST_ADMIN_NAME=TrendForgeAI
