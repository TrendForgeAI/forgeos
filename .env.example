# ForgeOS Environment Configuration
# Copy to .env and fill in your values. Never commit .env to Git.

# === Required ===
DOMAIN=forgeos.trend-forge.dev
SESSION_SECRET=change-me-to-a-random-64-char-string

# === User Mapping (match your host UID/GID) ===
FORGE_UID=1000
FORGE_GID=1000

# === Optional — can be set via Setup Wizard ===
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# FORGEOS_REPO=https://github.com/TrendForgeAI/forgeos.git
